_c = About;\nexport default About;\nvar _c;\n$RefreshReg$(_c, \"About\");","map":{"version":3,"names":["React","Footer","jsxDEV","_jsxDEV","About","className","children","fileName","_jsxFileName","lineNumber","columnNumber","_c","$RefreshReg$"],"sources":["C:/Users/Miroslav/Desktop/DiplomAppProgramm/frontend/src/pages/About/About.js"],"sourcesContent":["import React from \"react\";\r\nimport Footer from \"../../components/Footer/Footer\";\r\nimport \"./About.css\";\r\n\r\nconst About = () => {\r\n  return (\r\n    <div className=\"about-page\">\r\n      <div className=\"about-container\">\r\n        <h2>Про нас</h2>\r\n\r\n        <p>\r\n          Ласкаво просимо на нашу платформу подій! Ми створили сервіс для\r\n          пошуку, перегляду та реєстрації на професійні події: конференції,\r\n          семінари, воркшопи та майстер-класи у сфері IT, дизайну, аналітики\r\n          та бізнесу.\r\n        </p>\r\n\r\n        <h3>Місія платформи</h3>\r\n        <p>\r\n          Наша мета – допомогти професіоналам та студентам швидко знаходити\r\n          актуальні заходи у своїй сфері та зручно реєструватися на них без\r\n          зайвих клопотів. Ми прагнемо зробити процес участі в подіях простим\r\n          і доступним для всіх.\r\n        </p>\r\n\r\n        <h3>Можливості для користувачів</h3>\r\n        <ul>\r\n          <li>Перегляд усіх доступних професійних подій.</li>\r\n          <li>Пошук подій за ключовими словами та фільтрація за датою або локацією.</li>\r\n          <li>Реєстрація на конкретні події через зручну форму.</li>\r\n          <li>Отримання сповіщень про нові заходи та оновлення.</li>\r\n        </ul>\r\n\r\n        <h3>Можливості для організаторів та адміністраторів</h3>\r\n        <ul>\r\n          <li>Додавання нових подій та редагування існуючих.</li>\r\n          <li>Можливість перегляду списку зареєстрованих учасників.</li>\r\n          <li>Управління інформацією про заходи та їх деталями.</li>\r\n        </ul>\r\n\r\n        <h3>Команда</h3>\r\n        <p>\r\n          Наша команда складається з професіоналів у сфері IT, UX/UI дизайну\r\n          та управління подіями. Ми прагнемо створювати сучасні, безпечні та\r\n          зручні платформи для наших користувачів.\r\n        </p>\r\n\r\n        <h3>Контакти</h3>\r\n        <p>\r\n          Якщо у вас є питання або пропозиції, будь ласка, зв’яжіться з нами:\r\n        </p>\r\n        <ul>\r\n          <li>Email: miroslavurcenko9@gmail.com</li>\r\n          <li>Телеграм: @miroslav_yurchenko</li>\r\n        </ul>\r\n      </div>\r\n\r\n      <Footer />\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default About;"],"mappings":";AAAA,OAAOA,KAAK,MAAM,OAAO;AACzB,OAAOC,MAAM,MAAM,gCAAgC;AACnD,OAAO,aAAa;AAAC,SAAAC,MAAA,IAAAC,OAAA;AAErB,MAAMC,KAAK,GAAGA,CAAA,KAAM;EAClB,oBACED,OAAA;IAAKE,SAAS,EAAC,YAAY;IAAAC,QAAA,gBACzBH,OAAA;MAAKE,SAAS,EAAC,iBAAiB;MAAAC,QAAA,gBAC9BH,OAAA;QAAAG,QAAA,EAAI;MAAO;QAAAC,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAI,CAAC,eAEhBP,OAAA;QAAAG,QAAA,EAAG;MAKH;QAAAC,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAG,CAAC,eAEJP,OAAA;QAAAG,QAAA,EAAI;MAAe;QAAAC,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAI,CAAC,eACxBP,OAAA;QAAAG,QAAA,EAAG;MAKH;QAAAC,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAG,CAAC,eAEJP,OAAA;QAAAG,QAAA,EAAI;MAA2B;QAAAC,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAI,CAAC,eACpCP,OAAA;QAAAG,QAAA,gBACEH,OAAA;UAAAG,QAAA,EAAI;QAA0C;UAAAC,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAI,CAAC,eACnDP,OAAA;UAAAG,QAAA,EAAI;QAAqE;UAAAC,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAI,CAAC,eAC9EP,OAAA;UAAAG,QAAA,EAAI;QAAiD;UAAAC,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAI,CAAC,eAC1DP,OAAA;UAAAG,QAAA,EAAI;QAAiD;UAAAC,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAI,CAAC;MAAA;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACxD,CAAC,eAELP,OAAA;QAAAG,QAAA,EAAI;MAA+C;QAAAC,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAI,CAAC,eACxDP,OAAA;QAAAG,QAAA,gBACEH,OAAA;UAAAG,QAAA,EAAI;QAA8C;UAAAC,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAI,C