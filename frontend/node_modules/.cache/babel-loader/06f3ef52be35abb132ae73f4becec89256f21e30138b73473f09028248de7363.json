F. \\u041C\\u0438 \\u0432\\u0438\\u043A\\u043E\\u0440\\u0438\\u0441\\u0442\\u043E\\u0432\\u0443\\u0454\\u043C\\u043E \\u0441\\u0443\\u0447\\u0430\\u0441\\u043D\\u0438\\u0439 \\u0441\\u0442\\u0435\\u043A \\u0442\\u0435\\u0445\\u043D\\u043E\\u043B\\u043E\\u0433\\u0456\\u0439 (React, Node.js, MySQL), \\u0449\\u043E\\u0431 \\u0437\\u0430\\u0431\\u0435\\u0437\\u043F\\u0435\\u0447\\u0438\\u0442\\u0438 \\u0432\\u0438\\u0441\\u043E\\u043A\\u0443 \\u0448\\u0432\\u0438\\u0434\\u043A\\u0456\\u0441\\u0442\\u044C \\u0440\\u043E\\u0431\\u043E\\u0442\\u0438 \\u043D\\u0430\\u0432\\u0456\\u0442\\u044C \\u043F\\u0440\\u0438 \\u0432\\u0435\\u043B\\u0438\\u043A\\u0456\\u0439 \\u043A\\u0456\\u043B\\u044C\\u043A\\u043E\\u0441\\u0442\\u0456 \\u043A\\u043E\\u0440\\u0438\\u0441\\u0442\\u0443\\u0432\\u0430\\u0447\\u0456\\u0432 \\u043E\\u0434\\u043D\\u043E\\u0447\\u0430\\u0441\\u043D\\u043E.\"})]}),/*#__PURE__*/_jsxs(\"section\",{className:styles.contactBox,children:[/*#__PURE__*/_jsx(\"h3\",{children:\"\\u0417\\u0430\\u043B\\u0438\\u0448\\u0430\\u0439\\u0442\\u0435\\u0441\\u044F \\u043D\\u0430 \\u0437\\u0432'\\u044F\\u0437\\u043A\\u0443\"}),/*#__PURE__*/_jsx(\"p\",{children:\"\\u041C\\u0430\\u0454\\u0442\\u0435 \\u0456\\u0434\\u0435\\u044E, \\u044F\\u043A \\u043F\\u043E\\u043A\\u0440\\u0430\\u0449\\u0438\\u0442\\u0438 \\u043D\\u0430\\u0448 \\u0441\\u0435\\u0440\\u0432\\u0456\\u0441? \\u0410\\u0431\\u043E \\u0445\\u043E\\u0447\\u0435\\u0442\\u0435 \\u0441\\u0442\\u0430\\u0442\\u0438 \\u043D\\u0430\\u0448\\u0438\\u043C \\u043F\\u0430\\u0440\\u0442\\u043D\\u0435\\u0440\\u043E\\u043C?\"}),/*#__PURE__*/_jsxs(\"ul\",{className:styles.contactList,children:[/*#__PURE__*/_jsx(\"li\",{children:\"Email: miroslavurcenko9@gmail.com\"}),/*#__PURE__*/_jsx(\"li\",{children:\"Telegram: @miroslav_yurchenko\"})]})]})]}),/*#__PURE__*/_jsx(Footer,{})]});};export default About;","map":{"version":3,"names":["React","Footer","styles","jsx","_jsx","jsxs","_jsxs","About","className","aboutPage","children","aboutContainer","headerSection","contentSection","featureGrid","featureItem","contactBox","contactList"],"sources":["C:/Users/Miroslav/Desktop/events-app-repo/events-app/frontend/src/pages/About/About.js"],"sourcesContent":["import React from \"react\";\r\nimport Footer from \"../../components/Footer/Footer\";\r\nimport styles from \"./About.module.css\";\r\n\r\nconst About = () => {\r\n  return (\r\n    <div className={styles.aboutPage}>\r\n      <div className={styles.aboutContainer}>\r\n        \r\n        <section className={styles.headerSection}>\r\n          <h2>Про нашу платформу</h2>\r\n          <p>\r\n            Ми об'єднуємо активних людей та організаторів подій в єдину екосистему \r\n            для обміну досвідом та професійного розвитку.\r\n          </p>\r\n        </section>\r\n\r\n        <div className={styles.contentSection}>\r\n          <h3>Наша місія</h3>\r\n          <p>\r\n            Сьогодні інформаційний шум заважає знаходити справді важливі заходи. \r\n            Ми створили цей сервіс, щоб відфільтрувати зайве та надати вам прямий \r\n            доступ до найкращих конференцій, воркшопів та бізнес-зустрічей. \r\n            Ми віримо, що особисте спілкування та нетворкінг — це найшвидший шлях до успіху.\r\n          </p>\r\n\r\n          <h3>Що ми пропонуємо?</h3>\r\n          <div className={styles.featureGrid}>\r\n            <div className={styles.featureItem}>\r\n              <h4>Для учасників</h4>\r\n              <p>Повний каталог актуальних подій з можливістю миттєвої реєстрації та зручними фільтрами за локацією.</p>\r\n            </div>\r\n            <div className={styles.featureItem}>\r\n              <h4>Для спільноти</h4>\r\n              <p>Ми підтримуємо розвиток IT-ком'юніті, допомагаючи знаходити однодумців та наставників.</p>\r\n            </div>\r\n            <div className={styles.featureItem}>\r\n              <h4>Для організаторів</h4>\r\n              <p>Інструменти для управління базою учасників, збору аналітики та легкого додавання нових івентів.</p>\r\n            </div>\r\n          </div>\r\n\r\n          <h3>Наші цінності</h3>\r\n          <p>\r\n            <b>Прозорість:</b> Тільки актуальні дати та перевірені локації. <br/>\r\n            <b>Зручність:</b> Мінімум кліків для досягнення результату. <br/>\r\n            <b>Безпека:</b> Ваші дані захищені та використовуються лише для реєстрації на обрані заходи.<br/>\r\n          </p>\r\n\r\n          <h3>Технологічний розвиток</h3>\r\n          <p>\r\n            Наша платформа постійно вдосконалюється. Ми використовуємо сучасний стек \r\n            технологій (React, Node.js, MySQL), щоб забезпечити високу швидкість \r\n            роботи навіть при великій кількості користувачів одночасно.\r\n          </p>\r\n        </div>\r\n\r\n        <section className={styles.contactBox}>\r\n          <h3>Залишайтеся на зв'язку</h3>\r\n          <p>Маєте ідею, як покращити наш сервіс? Або хочете стати нашим партнером?</p>\r\n          <ul className={styles.contactList}>\r\n            <li>Email: miroslavurcenko9@gmail.com</li>\r\n            <li>Telegram: @miroslav_yurchenko</li>\r\n          </ul>\r\n        </section>\r\n      </div>\r\n\r\n      <Footer />\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default About;"],"mappings":"AAAA,MAAO,CAAAA,KAAK,KAAM,OAAO,CACzB,MAAO,CAAAC,MAAM,KAAM,gCAAgC,CACnD,MAAO,CAAAC,MAAM,KAAM,oBAAoB,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAExC,KAAM,CAAAC,KAAK,CAAGA,CAAA,GAAM,CAClB,mBACED,KAAA,QAAKE,SAAS,CAAEN,MAAM,CAACO,SAAU,CAAAC,QAAA,eAC/BJ,KAAA,QAAKE,SAAS,CAAEN,MAAM,CAACS,cAAe,CAAAD,QAAA,eAEpCJ,KAAA,YAASE,SAAS,CAAEN,MAAM,CAACU,aAAc,CAAAF,QAAA,eACvCN,IAAA,OAAAM,QAAA,CAAI,oGAAkB,CAAI,CAAC,cAC3BN,IAAA,MAAAM,QAAA,CAAG,qmBAGH,CAAG,CAAC,EACG,CAAC,cAEVJ,KAAA,QAAKE,SAAS,CAAEN,MAAM,CAACW,cAAe,CAAAH,QAAA,eACpCN,IAAA,OAAAM,QAAA,CAAI,yDAAU,CAAI,CAAC,cACnBN,IAAA,MAAAM,QAAA,CAAG,m8CAKH,CAAG,CAAC,cAEJN,IAAA,OAAAM,QAAA,CAAI,yFAAiB,CAAI,CAAC,cAC1BJ,KAAA,QAAKE,SAAS,CAAEN,MAAM,CAACY,WAAY,CAAAJ,QAAA,eACjCJ,